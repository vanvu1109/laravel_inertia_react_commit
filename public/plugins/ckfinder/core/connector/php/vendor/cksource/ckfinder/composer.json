{
    "name": "cksource/ckfinder",
    "description": "CKFinder PHP connector",
    "license": "proprietary",
    "authors": [
        {
            "name": "CKSource",
            "homepage": "http://cksource.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "symfony/http-kernel": "^8.0",
        "symfony/event-dispatcher": "^8.0",
        "symfony/http-foundation": "^8.0",
        "pimple/pimple": "^3.6",
        "monolog/monolog": "^3.9",
        "league/flysystem": "^3.30.0",
        "league/flysystem-aws-s3-v3": "^3.30.0",
        "ext-json": "*",
        "ext-gd": "*",
        "symfony/mime": "^8.0",
        "friendsofphp/php-cs-fixer": "^3.91",
        "league/flysystem-azure-blob-storage": "^3.0",
        "spatie/flysystem-dropbox": "^3.0",
        "league/flysystem-ftp": "^3.29.0",
        "ext-ftp": "*",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5.3",
        "mikey179/vfsstream": "^1.6.12",
        "league/flysystem-adapter-test-utilities": "^3.30.1"
    },
    "scripts": {
        "cs": [
            "php-cs-fixer fix"
        ],
        "build-doc": [
            "sh dev/doc/builddoc.sh"
        ],
        "update-locales": [
            "git subtree pull --prefix src/CKSource/CKFinder/locales translations master --squash"
        ]
    },
    "autoload": {
        "psr-0": {
            "CKSource": "src/"
        },
        "psr-4": {
            "CKSource\\CKFinder\\Plugin\\": "plugins/"
        }
    }
}
